{
  "name": "oh-my-pi",
  "version": "0.0.4-alpha",
  "description": "Desktop LLM assistant — like Codex for macOS",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "dev": "node dev.mjs",
    "dev:vite": "vite build --watch --config renderer/vite.config.ts",
    "start": "npm run build && electron .",
    "build": "vite build --config renderer/vite.config.ts",
    "typecheck": "tsc -p renderer/tsconfig.json --noEmit",
    "lint": "eslint .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.arkod.app",
    "productName": "Arkod",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Arkod ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "diff.js",
      "renderer/dist/**/*",
      "package.json",
      "lsp/**/*",
      "dap/**/*",
      "db/**/*",
      "http/**/*",
      "node_modules/**/*"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^26.15.3",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/search": "^6.5.9",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "mongodb": "^7.3.0",
    "mysql2": "^3.22.5",
    "node-pty": "^1.1.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "xlsx": "^0.18.5",
    "xterm": "^5.3.0"
  }
}
